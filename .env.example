# Copy this file to .env and fill in values for your environment.
# .env is git-ignored — never commit secrets.

# Required Postgres connection URL for Django.
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
# Optional query params are passed to libpq, e.g. ?sslmode=require&connect_timeout=30
# Supabase: prefer the direct host (db.<ref>.supabase.co:5432) for migrations; if you
# see timeouts or SSL errors, try the pooler (port 6543) or another network/VPN.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/monix
# Optional tuning when using Supabase/managed Postgres (defaults apply if unset):
# DATABASE_SSLMODE=require
# DATABASE_CONNECT_TIMEOUT=30

# Django secret key — generate a new one for production.
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production

# Set to False in production.
DEBUG=True

# Supabase (required for app auth when using Supabase Auth)
# SUPABASE_URL=https://<project-ref>.supabase.co
# Real user JWTs are RS256 — Django verifies them via JWKS (needs SUPABASE_URL).
# Leave SUPABASE_JWT_SECRET unset in production. Only set it for HS256 (e.g. local tests).
# SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_AUD=authenticated

# Canonical public URL of Django (scheme + host + port, no trailing slash).
# Used to build Google OAuth redirect_uris. In DEBUG, defaults to
# http://localhost:8000 if unset.
# DJANGO_PUBLIC_BASE_URL=http://localhost:8000

# Comma-separated list of allowed hostnames for Django (leave empty for local dev).
# ALLOWED_HOSTS=example.com,www.example.com

# Google PageSpeed Insights API key.
# Obtain one at https://developers.google.com/speed/docs/insights/v5/get-started
# Requests still work without a key but are subject to lower rate limits.
PAGESPEED_API_KEY=

# django-axes: admin login rate limiting.
# Lock out an IP after this many consecutive failed attempts (default: 5).
AXES_FAILURE_LIMIT=5
# Duration (in hours) before a locked-out IP is allowed to retry (default: 1).
AXES_COOLOFF_TIME=1

# --- Google OAuth (one redirect URI for sign-in + Search Console) ---
# Create an "OAuth 2.0 Client ID" with Application type: Web application.
# In Google Cloud Console → APIs & Services → Credentials → that client →
# "Authorized redirect URIs", add EXACTLY (copy/paste; trailing slash matters):
#
#   http://localhost:8000/api/auth/google/callback/
#
# Set GOOGLE_REDIRECT_URI (or legacy alias GOOGLE_REDIRECT_URL) to the same URL.
# Django routes that path: GSC responses include webmasters scope; sign-in
# does not (see api_auth_google_callback_compat).
#
# Optional "Authorized JavaScript origins" for local dev:
#   http://localhost:3000   http://localhost:8000
#
# OAuth consent screen: if Publishing status is "Testing", add your Google
# account under Test users — otherwise sign-in is blocked by policy.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback/
# Optional override for sign-in path only (default: /api/auth/google/callback/).
# GOOGLE_LOGIN_REDIRECT_PATH=/api/auth/google/callback/

# After Google Search Console OAuth, redirect browser here (Next.js URLs).
# GSC_OAUTH_SUCCESS_URL=http://localhost:3000/dashboard/projects?gsc=connected
# GSC_OAUTH_ERROR_URL=http://localhost:3000/dashboard/projects?gsc=error

# Optional: dedicated Fernet key for GSC refresh tokens and Cloudflare API tokens at rest
# (32 url-safe base64 bytes). When unset, a key is derived from DJANGO_SECRET_KEY instead.
# GOOGLE_REFRESH_TOKEN_FERNET_KEY=
