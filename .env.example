# Copy to `.env` at the repo root (git-ignored). Values here are used by Next.js
# when running from `web/` if you load them into the shell or duplicate into `web/.env.local`.

# --- Supabase (browser + server) ---
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: same project URL as above, service role for Postgres writes from route handlers
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# JWT verification for /api/* (production: RS256 via JWKS)
# SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_AUD=authenticated
# For local HS256 tests only (CI generates this dynamically):
# SUPABASE_JWT_SECRET=
# MONIX_VERIFY_SUPABASE_JWT=false

# Canonical public URL for SSR fetches to /api/* (no trailing slash)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional HS256 secret for short-lived GSC OAuth state JWTs
# MONIX_GSC_STATE_SECRET=

# --- Google OAuth (Search Console API) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Redirect URI must match Google Cloud Console exactly, e.g.:
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/gsc/callback

# GSC_OAUTH_SUCCESS_URL=http://localhost:3000/dashboard/integrations?gsc=connected
# GSC_OAUTH_ERROR_URL=http://localhost:3000/dashboard/integrations?gsc=error

# Optional: dedicated Fernet key for GSC refresh tokens + Cloudflare API tokens at rest
# GOOGLE_REFRESH_TOKEN_FERNET_KEY=
# Or set MONIX_FERNET_SECRET (otherwise a key may be derived from SUPABASE_SERVICE_ROLE_KEY)

# --- PageSpeed (optional) ---
# PAGESPEED_API_KEY=
